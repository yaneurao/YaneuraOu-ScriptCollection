#context Search_static_evaluation3

    if (priorReduction >= 2 && depth >= 2 && ss->staticEval + (ss - 1)->staticEval > 173@)
        depth--;

#context Search_razoring // search() Step 7.

    if (!PvNode && eval < alpha - 514@ - 294@ * depth * depth)
