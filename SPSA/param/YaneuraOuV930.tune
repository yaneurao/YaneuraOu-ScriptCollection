#context Search_futility_1 // Search step 8.

		auto futility_margin = [&](Depth d) {
            Value futilityMult = 91@ - 21@ * !ss->ttHit;

            return futilityMult * d                                //
                 - (2686@ * improving + 362@ * opponentWorsening) * futilityMult / 1024
