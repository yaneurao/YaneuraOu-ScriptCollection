{
    // 定期自動バックアップの間隔。単位は秒。
    // 10800 = 3時間。
    auto_save_interval_seconds: 10800,

    // この手数に到達したら、それ以上局面を掘らない。
    // nコマンドでも、この手数以降の局面は次の掘削対象として書き出さない。
    max_book_ply: 200,

    // peta_nextの開始局面集合ファイル。
    // このファイルが存在する場合、nコマンドはstartposではなく、
    // ここに書かれた局面集合から定跡ツリーを辿る。
    // nコマンド実行のたびに読み直される。
    peta_next_start_sfens_path: "book/peta_start_sfens.txt",
}
